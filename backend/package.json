    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "~5.5.4",
    "vitest": "^4.1.9"
  }
}
