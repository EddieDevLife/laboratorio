{
  "manifest_version": 3,
  "name": "Browser Agent",
  "version": "0.1.0",
  "description": "AI agent que navega o browser via accessibility tree",

  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],

  "optional_permissions": [
    "debugger"
  ],

  "host_permissions": [
    "https://api.openai.com/",
    "https://generativelanguage.googleapis.com/",
    "https://api.mistral.ai/",
    "https://api.groq.com/",
    "https://api.together.xyz/",
    "https://api.perplexity.ai/",
    "https://api.x.ai/",
    "https://openrouter.ai/"
  ],

  "optional_host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://api.openai.com https://generativelanguage.googleapis.com https://api.mistral.ai https://api.groq.com https://api.together.xyz https://api.perplexity.ai https://api.x.ai https://openrouter.ai"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Browser Agent"
  },

  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}
