{
  "manifest_version": 3,
  "name": "Browser Agent",
  "version": "0.1.0",
  "description": "AI agent que navega o browser via accessibility tree",

  "permissions": [
    "sidePanel",
    "tabs",
    "debugger",
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api.anthropic.com/",
    "https://api.openai.com/",
    "https://generativelanguage.googleapis.com/"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Browser Agent"
  },

  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}
